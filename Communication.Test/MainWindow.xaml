<Window
    x:Class="Communication.Test.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Communication.Test"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="665"
    Height="380"
    d:DataContext="{d:DesignInstance Type=local:MainWindowViewModel}"
    mc:Ignorable="d">

    <Window.Resources>
        <local:BoolToColorConverter x:Key="BoolToColor" />
        <local:ReverseBoolConverter x:Key="ReverseBool" />
        <local:EnumToBoolConverter x:Key="EnumToBool" />
        <local:LengthEnableConverter x:Key="LengthEnable" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>


        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition MaxHeight="20" />
            </Grid.RowDefinitions>

            <GroupBox
                Grid.Row="0"
                Margin="5,5,5,0"
                Header="ModBus RTU Test">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel
                        Grid.Column="0"
                        Margin="15,10,10,10"
                        HorizontalAlignment="Left">
                        <TextBlock Text="Port Name" />
                        <ComboBox
                            Width="120"
                            IsEnabled="{Binding IsConnected, Converter={StaticResource ReverseBool}}"
                            ItemsSource="{Binding Serials}"
                            SelectedItem="{Binding Config.PortName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,10,0,0" Text="Baud Rate" />
                        <ComboBox
                            Width="120"
                            IsEnabled="{Binding IsConnected, Converter={StaticResource ReverseBool}}"
                            ItemsSource="{Binding BaudRates}"
                            SelectedValue="{Binding Config.BaudRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,10,0,0" Text="Data Bits" />
                        <ComboBox
                            Width="120"
                            IsEnabled="{Binding IsConnected, Converter={StaticResource ReverseBool}}"
                            ItemsSource="{Binding Bits}"
                            SelectedValue="{Binding Config.DataBits, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,10,0,0" Text="Parity" />
                        <ComboBox
                            Width="120"
                            IsEnabled="{Binding IsConnected, Converter={StaticResource ReverseBool}}"
                            ItemsSource="{Binding ParityList}"
                            SelectedValue="{Binding Config.Parity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,10,0,0" Text="Stop Bit" />
                        <ComboBox
                            Width="120"
                            IsEnabled="{Binding IsConnected, Converter={StaticResource ReverseBool}}"
                            ItemsSource="{Binding StopBitsList}"
                            SelectedValue="{Binding Config.StopBits, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        Margin="0,10,10,10"
                        HorizontalAlignment="Left">

                        <TextBlock Text="Slave ID" />
                        <TextBox
                            Width="120"
                            Height="20"
                            FontSize="12"
                            Text="{Binding Tx.SlaveId}" />

                        <TextBlock Margin="0,10,0,0" Text="Start" />
                        <TextBox
                            Width="120"
                            Height="20"
                            FontSize="12"
                            Text="{Binding Tx.Start}" />

                        <TextBlock Margin="0,10,0,0" Text="Length" />
                        <TextBox
                            Width="120"
                            Height="20"
                            FontSize="12"
                            Text="{Binding Length, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,10,0,0" Text="Region" />
                        <ComboBox
                            Width="120"
                            ItemsSource="{Binding RegionList}"
                            SelectedValue="{Binding Tx.FunctionCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Button
                            Width="120"
                            Height="20"
                            Margin="0,10,0,0"
                            Command="{Binding ConnectCommand}"
                            Content="Connect"
                            IsEnabled="{Binding IsConnected, Converter={StaticResource ReverseBool}}" />

                        <Button
                            Width="120"
                            Height="20"
                            Margin="0,10,0,0"
                            Command="{Binding ExecuteCommand}"
                            Content="Execute" />

                        <Button
                            Width="120"
                            Height="20"
                            Margin="0,10,0,0"
                            Command="{Binding DisconnectCommand}"
                            Content="Disconnect"
                            IsEnabled="{Binding IsConnected}" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition MaxWidth="30" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Ellipse
                    Grid.Column="0"
                    Width="10"
                    Height="10"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Fill="{Binding IsConnected, Converter={StaticResource BoolToColor}}" />

                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Text="{Binding Config.PortName}" />
            </Grid>
        </Grid>


        <DataGrid
            Grid.Column="1"
            Width="300"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserResizeColumns="False"
            EnableRowVirtualization="True"
            HeadersVisibility="Column"
            HorizontalScrollBarVisibility="Hidden"
            IsReadOnly="{Binding Tx.FunctionCode, Converter={StaticResource EnumToBool}}"
            ItemsSource="{Binding DataList}"
            VerticalScrollBarVisibility="Hidden">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding Address}"
                    Header="0x"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="200"
                    Binding="{Binding Value}"
                    Header="Value"
                    IsReadOnly="{Binding Tx.FunctionCode, Converter={StaticResource EnumToBool}}" />
            </DataGrid.Columns>

            <!--  <DataGrid.  -->
        </DataGrid>
    </Grid>

</Window>
